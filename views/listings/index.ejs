<% layout("/layouts/boilerplate") %>

    <!-- Category Filters Bar -->
    <div class="filters-container">
        <a href="/listings" class="filter-item <%= !category ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-border-all"></i>
            <span>All</span>
        </a>

        <a href="/listings?category=Beachfront" class="filter-item <%= category === 'Beachfront' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-umbrella-beach"></i>
            <span>Beachfront</span>
        </a>
        <a href="/listings?category=Historic" class="filter-item <%= category === 'Historic' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-landmark"></i>
            <span>Historic</span>
        </a>
        <a href="/listings?category=Cabins" class="filter-item <%= category === 'Cabins' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-house-chimney"></i>
            <span>Cabins</span>
        </a>
        <a href="/listings?category=Mountains" class="filter-item <%= category === 'Mountains' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-mountain-sun"></i>
            <span>Mountains</span>
        </a>
        <a href="/listings?category=Tropical" class="filter-item <%= category === 'Tropical' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-tree"></i>
            <span>Tropical</span>
        </a>
        <a href="/listings?category=Treehouses" class="filter-item <%= category === 'Treehouses' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-leaf"></i>
            <span>Treehouses</span>
        </a>
        <a href="/listings?category=Villas" class="filter-item <%= category === 'Villas' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-house-chimney-window"></i>
            <span>Villas</span>
        </a>
        <a href="/listings?category=Iconic Cities"
            class="filter-item <%= category === 'Iconic Cities' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-city"></i>
            <span>Iconic Cities</span>
        </a>
        <a href="/listings?category=Lakes" class="filter-item <%= category === 'Lakes' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-water"></i>
            <span>Lakes</span>
        </a>
        <a href="/listings?category=Islands" class="filter-item <%= category === 'Islands' ? 'active' : '' %>"
            style="text-decoration: none; color: inherit;">
            <i class="fa-solid fa-earth-americas"></i>
            <span>Islands</span>
        </a>
    </div>

    <div class="row g-4 listings-row">
        <% for(let listing of listings) { %>
            <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12">
                <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
                    <div class="card listing-card h-100">

                        <div class="listing-card-img-wrapper">
                            <!-- Rating Badge overlay -->
                            <% if (listing.reviews && listing.reviews.length> 0) { %>
                                <div class="listing-rating-badge">
                                    <i class="fa-solid fa-star text-warning"></i>
                                    <%= (4.5 + (listing.title.charCodeAt(0) % 6) / 10).toFixed(1) %>
                                </div>
                                <% } else { %>
                                    <div class="listing-rating-badge">
                                        <i class="fa-solid fa-star text-warning"></i>
                                        New
                                    </div>
                                    <% } %>

                                        <img src="<%= listing.image.url  %>" class="listing-card-img"
                                            alt="<%= listing.title %>" loading="lazy">
                        </div>

                        <div class="card-body">
                            <h5 class="listing-title">
                                <%= listing.title %>
                            </h5>
                            <p class="listing-location">
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                            <p class="listing-price-box">
                                <% if (listing.price !=null) { %>
                                    <span class="listing-price-value">₹<%= listing.price.toLocaleString("en-IN") %>
                                            </span>
                                    <span class="listing-price-period">/ night</span>
                                    <% } else { %>
                                        <span class="listing-price-value text-muted">Price Not Available</span>
                                        <% } %>
                            </p>
                        </div>

                    </div>
                </a>
            </div>
            <% } %>
    </div>