<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center py-4">
    <div class="col-12 col-md-10 col-lg-8">
        
        <div class="form-card shadow-lg p-5">
            <div class="d-flex align-items-center gap-3 mb-4 pb-2 border-bottom">
                <i class="fa-solid fa-hotel text-danger" style="font-size: 28px;"></i>
                <h3 class="fw-bold mb-0">List Your Retreat</h3>
            </div>

            <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

                <!-- Title -->
                <div class="mb-4">
                    <label for="title" class="form-label">Retreat Title</label>
                    <input
                        type="text"
                        name="listing[title]"
                        id="title"
                        class="form-control"
                        placeholder="e.g. Serene Mountain Chalet"
                        required
                    >
                    <div class="valid-feedback">
                        Looks wonderful!
                    </div>
                    <div class="invalid-feedback">
                        Please enter a beautiful title for your listing.
                    </div>
                </div>

                <!-- Description -->
                <div class="mb-4">
                    <label for="description" class="form-label">Description</label>
                    <textarea
                        name="listing[description]"
                        id="description"
                        rows="5"
                        class="form-control"
                        placeholder="Tell guests about your place, the view, nearby attractions, and amenities..."
                        required
                    ></textarea>
                    <div class="valid-feedback">
                        Terrific description!
                    </div>
                    <div class="invalid-feedback">
                        Please provide a description of your property.
                    </div>
                </div>

                <!-- Image URL -->
                <div class="mb-4">
                    <label for="image" class="form-label">Upload Image</label>
                    <input 
                        type="file"
                        name="listing[image]"
                        id="image"
                        class="form-control"
                        placeholder="e.g. https://images.unsplash.com/... (optional)"
                    >
                    <div class="form-text text-muted">Provide file. If left blank, a high-quality default image will be set automatically.</div>
                </div>

                <!-- Price and Location Row -->
                <div class="row">
                    <!-- Price -->
                    <div class="col-12 col-md-6 mb-4">
                        <label for="price" class="form-label">Price per Night (₹)</label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0 bg-white" style="border-radius: 10px 0 0 10px;">₹</span>
                            <input
                                type="number"
                                name="listing[price]"
                                id="price"
                                class="form-control border-start-0"
                                placeholder="1200"
                                min="0"
                                style="border-radius: 0 10px 10px 0;"
                                required
                            >
                        </div>
                        <div class="invalid-feedback">
                            Please set a valid price per night.
                        </div>
                    </div>

                    <!-- Location -->
                    <div class="col-12 col-md-6 mb-4">
                        <label for="location" class="form-label">Location / City</label>
                        <input
                            type="text"
                            name="listing[location]"
                            id="location"
                            class="form-control"
                            placeholder="e.g. Manali, Himachal Pradesh"
                            required
                        >
                        <div class="invalid-feedback">
                            Please provide the location.
                        </div>
                    </div>
                </div>

                <!-- Country -->
                <div class="mb-4">
                    <label for="country" class="form-label">Country</label>
                    <input
                        type="text"
                        name="listing[country]"
                        id="country"
                        class="form-control"
                        placeholder="e.g. India"
                        required
                    >
                    <div class="invalid-feedback">
                        Please provide the country name.
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex align-items-center gap-3 mt-4 pt-3">
                    <button type="submit" class="btn btn-primary-custom px-4 py-2.5 rounded-pill w-auto">
                        <i class="fa-solid fa-circle-plus me-1"></i> Add Listing
                    </button>
                    <a href="/listings" class="btn btn-outline-custom px-4 py-2.5 rounded-pill w-auto">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>