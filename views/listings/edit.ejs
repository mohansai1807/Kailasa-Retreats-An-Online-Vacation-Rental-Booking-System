<% layout("/layouts/boilerplate") %>

    <div class="row justify-content-center py-4">
        <div class="col-12 col-md-10 col-lg-8">

            <div class="form-card shadow-lg p-5">
                <div class="d-flex align-items-center gap-3 mb-4 pb-2 border-bottom">
                    <i class="fa-solid fa-pen-to-square text-danger" style="font-size: 28px;"></i>
                    <h3 class="fw-bold mb-0">Edit Your Retreat</h3>
                </div>

                <!-- Current Image Preview -->
                <% if (listing.image) { %>
                    <div class="mb-4 text-center">
                        <p class="form-label text-start mb-2">Current Listing Image</p>

                        <div class="mx-auto rounded-4 overflow-hidden shadow-sm"
                            style="width: 100%; max-width: 900px; height: 450px;">
                            <img src="<%= listing.image.url%>" alt="Current Image" class="w-100 h-100"
                                style="object-fit: cover;">
                        </div>
                    </div>
                    <% } %>

                        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate
                            class="needs-validation">

                            <!-- Title -->
                            <div class="mb-4">
                                <label for="title" class="form-label">Retreat Title</label>
                                <input type="text" name="listing[title]" id="title" value="<%= listing.title %>"
                                    class="form-control" placeholder="Add listing title" required>
                                <div class="invalid-feedback">
                                    Please enter a valid title.
                                </div>
                            </div>

                            <!-- Description -->
                            <div class="mb-4">
                                <label for="description" class="form-label">Description</label>
                                <textarea name="listing[description]" id="description" rows="5" class="form-control"
                                    placeholder="Update listing description"
                                    required><%= listing.description %></textarea>
                                <div class="invalid-feedback">
                                    Please enter a description.
                                </div>
                            </div>

                            <!-- Price and Location Row -->
                            <div class="row">
                                <!-- Price -->
                                <div class="col-12 col-md-6 mb-4">
                                    <label for="price" class="form-label">Price per Night (₹)</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-end-0 bg-white"
                                            style="border-radius: 10px 0 0 10px;">₹</span>
                                        <input type="number" name="listing[price]" id="price"
                                            value="<%= listing.price %>" class="form-control border-start-0" min="0"
                                            style="border-radius: 0 10px 10px 0;" required>
                                    </div>
                                    <div class="invalid-feedback">
                                        Please enter a valid price.
                                    </div>
                                </div>

                                <!-- Location -->
                                <div class="col-12 col-md-6 mb-4">
                                    <label for="location" class="form-label">Location / City</label>
                                    <input type="text" name="listing[location]" id="location"
                                        value="<%= listing.location %>" class="form-control"
                                        placeholder="Tirupati, Andhra Pradesh" required>
                                    <div class="invalid-feedback">
                                        Please enter a location.
                                    </div>
                                </div>
                            </div>

                            <!-- Image URL -->
                            <div class="mb-4">
                                <label for="image" class="form-label">Image URL</label>
                                <input type="url" id="image" 
                                    class="form-control" placeholder="Image URL link">
                            </div>

                            <!-- Country -->
                            <div class="mb-4">
                                <label for="country" class="form-label">Country</label>
                                <input type="text" name="listing[country]" id="country" value="<%= listing.country %>"
                                    class="form-control" required>
                                <div class="invalid-feedback">
                                    Please enter a country.
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-flex align-items-center gap-3 mt-4 pt-3">
                                <button type="submit" class="btn btn-primary-custom px-4 py-2.5 rounded-pill w-auto">
                                    <i class="fa-solid fa-floppy-disk me-1"></i> Save Changes
                                </button>
                                <a href="/listings/<%= listing._id %>"
                                    class="btn btn-outline-custom px-4 py-2.5 rounded-pill w-auto">
                                    Cancel
                                </a>
                            </div>

                        </form>
            </div>
        </div>
    </div>