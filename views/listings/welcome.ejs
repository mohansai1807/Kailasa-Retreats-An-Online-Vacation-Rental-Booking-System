<% layout("/layouts/boilerplate") %>
<div class="welcome-page">
    <div class="welcome-grid">
        <section class="welcome-copy">
            <span class="welcome-eyebrow">Explore your next escape</span>
            <h1 class="welcome-title">Discover beautiful stays and retreats for every mood.</h1>
            <p class="welcome-subtitle">Browse top-rated listings, handpicked locations, and specially curated experiences for your next getaway.</p>
            <a href="/listings" class="btn welcome-btn edit-btn">Browse All Listings</a>
        </section>

        <section class="welcome-visual">
            <div class="hero-card">
                <span class="hero-tag">Featured escape</span>
                <h2>Lakeview Cottage</h2>
                <p>Relax in a peaceful lakeside home with stunning views, cozy interiors, and private access to the water.</p>
                <div class="hero-stats">
                    <div class="hero-stat">
                        <strong>4.9</strong>
                        <span>Guest rating</span>
                    </div>
                    <div class="hero-stat">
                        <strong>₹ 4,499</strong>
                        <span>Per night</span>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
