<% layout("/layouts/boilerplate") %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">

            <!-- Page Header -->
            <div class="text-center mb-5">
                <div class="contact-icon-ring mx-auto mb-3">
                    <i class="fa-solid fa-headset"></i>
                </div>
                <h1 class="fw-bold" style="font-size:32px;">Get in Touch</h1>
                <p class="text-muted" style="font-size:16px;max-width:480px;margin:0 auto;">
                    Have a question about a listing, booking, or anything else? We're here to help.
                </p>
            </div>

            <!-- Contact Info Row -->
            <div class="row g-3 mb-5">
                <div class="col-md-4">
                    <div class="contact-info-card text-center">
                        <i class="fa-solid fa-envelope text-danger mb-2" style="font-size:22px;"></i>
                        <p class="fw-semibold mb-1" style="font-size:14px;">Email Us</p>
                        <p class="text-muted mb-0" style="font-size:13px;">saikmohan1@gmail.com</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="contact-info-card text-center">
                        <i class="fa-solid fa-phone text-danger mb-2" style="font-size:22px;"></i>
                        <p class="fw-semibold mb-1" style="font-size:14px;">Call Us</p>
                        <p class="text-muted mb-0" style="font-size:13px;">+91 7396484821</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="contact-info-card text-center">
                        <i class="fa-solid fa-clock text-danger mb-2" style="font-size:22px;"></i>
                        <p class="fw-semibold mb-1" style="font-size:14px;">Response Time</p>
                        <p class="text-muted mb-0" style="font-size:13px;">Within 24–48 hours</p>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="form-card shadow-lg p-5">
                <h3 class="fw-bold mb-1">Send Us a Message</h3>
                <p class="text-muted mb-4" style="font-size:14px;">Fill in the form below and we'll get back to you shortly.</p>

                <form action="/contact" method="POST" class="needs-validation" novalidate id="contactForm">

                    <div class="row">
                        <!-- Full Name -->
                        <div class="col-12 col-md-6 mb-4">
                            <label for="contact-name" class="form-label">Full Name <span class="text-danger">*</span></label>
                            <input type="text" name="name" id="contact-name" class="form-control"
                                placeholder="Your full name" required>
                            <div class="invalid-feedback">Please enter your name.</div>
                        </div>
                        <!-- Email -->
                        <div class="col-12 col-md-6 mb-4">
                            <label for="contact-email" class="form-label">Email Address <span class="text-danger">*</span></label>
                            <input type="email" name="email" id="contact-email" class="form-control"
                                placeholder="your@email.com" required>
                            <div class="invalid-feedback">Please enter a valid email address.</div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Phone -->
                        <div class="col-12 col-md-6 mb-4">
                            <label for="contact-phone" class="form-label">Phone <span class="text-muted" style="font-size:12px;">(optional)</span></label>
                            <input type="tel" name="phone" id="contact-phone" class="form-control"
                                placeholder="+91 00000 00000">
                        </div>
                        <!-- Subject -->
                        <div class="col-12 col-md-6 mb-4">
                            <label for="contact-subject" class="form-label">Subject <span class="text-danger">*</span></label>
                            <select name="subject" id="contact-subject" class="form-control" required>
                                <option value="" disabled selected>Select a subject</option>
                                <option>Booking Inquiry</option>
                                <option>Listing Question</option>
                                <option>Payment / Refund</option>
                                <option>Technical Support</option>
                                <option>Partnership / Hosting</option>
                                <option>Other</option>
                            </select>
                            <div class="invalid-feedback">Please select a subject.</div>
                        </div>
                    </div>

                    <!-- Message -->
                    <div class="mb-4">
                        <label for="contact-message" class="form-label">Message <span class="text-danger">*</span></label>
                        <textarea name="message" id="contact-message" rows="5" class="form-control"
                            placeholder="Describe your query in detail..." required></textarea>
                        <div class="invalid-feedback">Please enter your message.</div>
                        <div class="d-flex justify-content-end mt-1">
                            <small class="text-muted" id="charCount">0 / 1000</small>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary-custom px-5 py-2 rounded-pill">
                        <i class="fa-solid fa-paper-plane me-2"></i> Send Message
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
// Bootstrap form validation
(function () {
    const form = document.getElementById('contactForm');
    form.addEventListener('submit', (e) => {
        if (!form.checkValidity()) {
            e.preventDefault();
            e.stopPropagation();
        }
        form.classList.add('was-validated');
    });
})();

// Character counter for message
const msgArea = document.getElementById('contact-message');
const charCount = document.getElementById('charCount');
msgArea.addEventListener('input', () => {
    const len = msgArea.value.length;
    charCount.textContent = `${len} / 1000`;
    if (len > 900) charCount.style.color = '#ff385c';
    else charCount.style.color = '';
    if (len > 1000) msgArea.value = msgArea.value.slice(0, 1000);
});
</script>
